# Template for the UniFi controller credentials used by the local Terraform in
# terraform/unifi/ (via tf.sh). Auth = API key (no login -> no login rate-limits).
# NOT Flux-reconciled; local CLI only.
#
# Setup:
#   1. cp credentials.sops.yaml.example credentials.sops.yaml
#   2. Set UNIFI_API_KEY (reuse the key from apps/base/ui-toolkit/ui-toolkit-secret,
#      or mint one in UniFi -> Settings -> Admins -> your user -> Create API Key)
#      and the two SSID passphrases.
#   3. sops --encrypt --in-place scripts/unifi/credentials.sops.yaml
#   4. Verify it shows ENC[...] before committing.
stringData:
  UNIFI_API: https://192.168.1.1
  UNIFI_API_KEY: REPLACE_ME
  UNIFI_INSECURE: "true"
  UNIFI_SITE: default
  TF_VAR_guest_psk: REPLACE_ME
  TF_VAR_kids_psk: REPLACE_ME
