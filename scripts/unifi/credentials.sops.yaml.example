# Template for the UniFi controller admin credentials used by the local Terraform
# in terraform/unifi/ (via tf.sh). NOT Flux-reconciled — local CLI only.
#
# Setup:
#   1. cp credentials.sops.yaml.example credentials.sops.yaml
#   2. Fill in the real UNIFI_PASSWORD (from the dedicated local admin you created).
#   3. sops --encrypt --in-place scripts/unifi/credentials.sops.yaml
#   4. Verify it shows ENC[...] before committing — the *.sops.yaml suffix alone
#      does NOT guarantee encryption.
stringData:
  UNIFI_API: https://192.168.1.1
  UNIFI_USERNAME: claude-tf
  UNIFI_PASSWORD: REPLACE_ME
  UNIFI_INSECURE: "true"
  UNIFI_SITE: default
