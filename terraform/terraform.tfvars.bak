#########################
# Proxmox connection
#########################

pm_api_url    = "https://192.168.1.107:8006/api2/json"
pm_tls_insecure = true

# From your Proxmox UI:
# Token ID:   root@pam!terraform
# Secret:     476daf6b-94fc-413e-9b1c-4fbdda98e80c
pm_token_name  = "root@pam!terraform"
pm_token_value = "26a3e503-a04b-4677-8c13-fe9168ef0c17"  # <--- your secret, locally only

#########################
# Cluster basics
#########################

cluster_name     = "questing-k3s"
proxmox_node     = "pve-whistler"           # where VMs will live
vm_storage       = "local"                  # your storage ID
vm_bridge        = "vmbr0.90"               # Linux VLAN bridge
vm_template_name = "questing-server-cloudimg-amd64.img"

# Networking
vm_gateway   = "192.168.90.1"
vm_dns       = "192.168.1.1"                # or whatever DNS you prefer
kube_vip_ip  = "192.168.90.160"

# MetalLB range for LoadBalancer services
metallb_ip_range_start = "192.168.90.180"
metallb_ip_range_end   = "192.168.90.199"

#########################
# Node definitions
#########################

