apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: kube-vip-ds
  namespace: kube-system
spec:
  selector:
    matchLabels:
      app: kube-vip
  template:
    metadata:
      labels:
        app: kube-vip
    spec:
      hostNetwork: true
      serviceAccountName: kube-vip

      # Only run on control-plane nodes
      nodeSelector:
        node-role.kubernetes.io/control-plane: "true"

      tolerations:
        - key: "node-role.kubernetes.io/control-plane"
          operator: "Exists"
          effect: "NoSchedule"
        - key: "node-role.kubernetes.io/master"
          operator: "Exists"
          effect: "NoSchedule"

      containers:
        - name: kube-vip
          image: {{ kubevip_image }}
          imagePullPolicy: IfNotPresent
          args:
            - manager
          env:
            # Interface that has the 192.168.90.x address
            - name: vip_interface
              value: "{{ kubevip_interface }}"

            # Virtual IP for the API
            - name: vip_address
              value: "{{ kubevip_vip }}"

            # Single IP, not a range
            - name: vip_cidr
              value: "32"

            # Enable ARP mode so kube-vip actually announces the VIP
            - name: vip_arp
              value: "true"

            # Control-plane HA mode
            - name: cp_enable
              value: "true"
            - name: cp_namespace
              value: "kube-system"

            # We are *not* using kube-vip for Service LoadBalancers right now
            - name: svc_enable
              value: "false"

          securityContext:
            capabilities:
              add:
                - NET_ADMIN
                - NET_RAW
            privileged: true